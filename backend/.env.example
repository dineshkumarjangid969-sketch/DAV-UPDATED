# DAV Transport Backend Environment
PORT=5000
DOCLING_URL=http://localhost:8000

# Twilio WhatsApp (optional - for WhatsApp notifications)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
WHATSAPP_GROUP_NUMBERS=+6421XXXXXXX,+6422XXXXXXX

# Database (SQLite is default, no config needed)
# For PostgreSQL: DATABASE_URL=postgresql://user:pass@localhost:5432/dav_transport
